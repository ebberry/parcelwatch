# ParcelWatch — environment variables.
# Copy to `.env` (gitignored) and fill in. NEVER commit real secrets.

# ----- Core -----
NODE_ENV=development

# ----- Database: Postgres + PostGIS -----
# Defaults match docker-compose.yml.
DATABASE_URL=postgres://parcelwatch:parcelwatch@localhost:5432/parcelwatch

# ----- Cache / job queue: Redis -----
REDIS_URL=redis://localhost:6379

# ----- U.S. Census ACS (neighborhood statistics) -----
# Free key from https://api.census.gov/data/key_signup.html
# Keyless ACS access was retired; the neighborhood panel needs this to load.
# (The Census geocoder used to find the tract is keyless and needs no key.)
CENSUS_API_KEY=

# ----- Feature flags -----
# true = require real Auth.js sign-in; false = dev session (no login, local work).
AUTH_ENABLED=true
# Stripe is NOT integrated until explicitly confirmed. Keep false.
PAYMENTS_ENABLED=false

# ----- ArcGIS (your existing subscription) -----
# Used ONLY by the client-side map layer (basemap + Esri geocoder). Adapters
# fetch King County's hosted feature services with keyless REST where possible.
# NEXT_PUBLIC_ prefix = exposed to the browser. Do not put privileged keys here.
NEXT_PUBLIC_ARCGIS_API_KEY=

# ----- Auth.js magic-link -----
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=
# EMAIL_SERVER is the SMTP/Resend connection for production. When blank, the dev
# transport logs the magic link to the console + /tmp/parcelwatch-magic-link.txt.
EMAIL_SERVER=
EMAIL_FROM=ParcelWatch <noreply@parcelwatch.local>

# ----- Watch poller (optional) -----
# When set, POST /api/watches/poll requires Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=

# ----- Stripe (Phase 6 — DO NOT integrate until confirmed) -----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
