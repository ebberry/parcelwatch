# ParcelWatch production env — copy to deploy/.env.production and fill in.
# This file is loaded BOTH for compose variable substitution (DOMAIN,
# POSTGRES_PASSWORD) and as the app's env_file. NEVER commit the filled-in copy.

# ----- Domain (Caddy TLS + Auth.js canonical URL) -----
# Recommended: a SUBDOMAIN of your domain, e.g. parcelwatch.yourdomain.com, with
# a DNS A record -> your Lightsail static IP (your apex domain stays untouched).
# No domain? Use sslip.io: DOMAIN=52-10-20-30.sslip.io needs zero DNS setup.
# Either way, Caddy gets a real Let's Encrypt cert automatically.
DOMAIN=parcelwatch.example.com
AUTH_URL=https://parcelwatch.example.com
AUTH_TRUST_HOST=true

# ----- Database (Postgres service in the compose stack) -----
# Keep POSTGRES_PASSWORD and the password in DATABASE_URL in sync.
POSTGRES_PASSWORD=CHANGE_ME_strong_password
DATABASE_URL=postgres://parcelwatch:CHANGE_ME_strong_password@db:5432/parcelwatch

# ----- Redis (BullMQ scheduler) -----
REDIS_URL=redis://redis:6379

# ----- Auth.js -----
# openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_generate_a_secret
AUTH_ENABLED=true

# ----- Email (magic links). With EMAIL_SERVER set, links are actually sent. -----
# Resend SMTP: use smtps:// for port 465 (implicit TLS), or smtp:// for 587 (STARTTLS).
# (Amazon SES SMTP creds work the same way.)
# MVP NOTE: until you verify a domain in Resend, you can only send FROM
# onboarding@resend.dev and only TO your own Resend signup email. That's fine to
# demo with — sign in as yourself. Verify a domain later to email anyone.
EMAIL_SERVER=smtps://resend:RESEND_API_KEY@smtp.resend.com:465
EMAIL_FROM=ParcelWatch <onboarding@resend.dev>

# ----- AI layer (Anthropic / Claude) — civic relevance + plain-language summaries
# Optional. Unset = the council feed degrades to keyword topics (nothing breaks).
# Get a key at https://console.anthropic.com. Cost is tiny (small model, cached).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ----- U.S. Census ACS (neighborhood stats) -----
CENSUS_API_KEY=

# ----- Watch poller trigger guard -----
# openssl rand -hex 16 — protects POST /api/watches/poll if you trigger it externally.
CRON_SECRET=CHANGE_ME_random

NODE_ENV=production
