# Caddy auto-provisions and renews a free Let's Encrypt cert for {$DOMAIN}.
# Requires: {$DOMAIN} resolves to the Lightsail static IP (a real domain's A
# record, OR an <ip>.sslip.io name which needs no DNS setup), and ports 80 + 443
# open in the Lightsail firewall.
{$DOMAIN} {
	encode zstd gzip
	reverse_proxy web:3000
}
